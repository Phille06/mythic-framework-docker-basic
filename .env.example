# =============================================================================
# FiveM + txAdmin + Mythic Framework — Environment Variables
# =============================================================================
# Credits:
#   FiveM Docker image originally by ich777 (admin@minenet.at)
#     https://github.com/ich777/docker-fivem-server
#   Forked by Phille06
#     https://github.com/Phille06/mythic-framework-docker
# =============================================================================
# 1. Copy:   cp .env.example .env
# 2. Edit:   nano .env   — fill in every value below
# 3. Start:  docker compose up -d
#
# NEVER commit .env with real secrets — it is listed in .gitignore
# =============================================================================

# --- MariaDB ------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=ChangeMeRootPass!
MYSQL_DATABASE=fivem
MYSQL_USER=fivem
MYSQL_PASSWORD=ChangeMeDBPass!

# --- MongoDB ------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=ChangeMeMongoPass!
MONGO_INITDB_DATABASE=fivem

# --- FiveM / FXServer ---------------------------------------------------------
# Cfx.re license key — https://keymaster.fivem.net
SERVER_LICENSE_KEY=cfxk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Display name in the FiveM server browser
SERVER_NAME=My Mythic Server

# Game port TCP + UDP (default 30120)
FIVEM_PORT=30120

# txAdmin web panel port (default 40120)
TXADMIN_PORT=40120

# --- Mythic recipe URL --------------------------------------------------------
RECIPE_URL=https://raw.githubusercontent.com/Mythic-Framework/txAdminRecipe/main/mythic-stable.yaml

# --- ich777 / Phille06 base image settings ------------------------------------
# Leave blank = auto-download latest FXServer artifact on every restart
# Set to "true" = skip auto-update (place fx.tar.xz in ./data/serverfiles/)
MANUAL_UPDATES=
# Leave blank to enable txAdmin (recommended)
# Set to "server.cfg" to bypass txAdmin and start directly
GAME_CONFIG=

# Container user/group ID (99/100 is Unraid default, works on most Linux hosts)
PUID=99
PGID=100
